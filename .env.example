# Variables EXPO_PUBLIC_* : embarquées EN CLAIR dans le bundle JS — jamais de secret ici.
# Copier ce fichier en `.env` (non versionné) pour surcharger en local.

# "off" pour désactiver toute la monétisation (tout devient gratuit).
EXPO_PUBLIC_MONETIZATION=on

# Clé SDK publique RevenueCat (plateforme Apple) — publiable par conception.
# Vide = provider noop (achats désactivés), utile en dev/Expo Go.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
